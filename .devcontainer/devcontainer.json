{
  "name": "Java 11 Pilha RN",
  "image": "mcr.microsoft.com/devcontainers/java:1-11-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/maven-sdkman:2": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vscjava.vscode-maven",
        "vscjava.vscode-java-test"
      ]
    }
  },
  "postCreateCommand": "mvn -v",
  "remoteUser": "vscode"
}
